# Скопируйте этот файл в .env и заполните своими значениями.
#   cp .env.example .env
# Файл .env в .gitignore — реальные пароли в репозиторий не попадут.

# --- Доступ в админку ---
ADMIN_PASSWORD=смените_меня
COOKIE_SECRET=длинная_случайная_строка

# --- Порт (необязательно) ---
# PORT=3000

# --- Почта для писем-подтверждений (SMTP) ---
# Пример для Яндекс.Почты (нужен «пароль приложения», не основной пароль):
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=priem@yandex.ru
#   SMTP_PASS=пароль_приложения
#   SMTP_FROM=Приём Солнечногорск <priem@yandex.ru>
#
# Пример для Mail.ru:
#   SMTP_HOST=smtp.mail.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# Если оставить SMTP_HOST пустым — письма не отправляются, а пишутся в лог.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
