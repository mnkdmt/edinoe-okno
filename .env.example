# Скопируйте этот файл в .env и заполните нужное:
#   cp .env.example .env
# Файл .env в .gitignore — реальные пароли в репозиторий не попадут.
#
# ВАЖНО: строки, начинающиеся с #, не действуют. Раскомментируйте (уберите #)
# только то, что реально задаёте. Пока строка закомментирована — работает
# значение по умолчанию.

# --- Доступ в админку (по умолчанию пароль admin) ---
# Раскомментируйте и задайте свои перед реальным запуском:
# ADMIN_PASSWORD=придумайте_пароль
# COOKIE_SECRET=длинная_случайная_строка

# --- Порт (по умолчанию 3000) ---
# PORT=3000

# --- Почта для писем-подтверждений (SMTP) ---
# Заполните все 5 строк ниже, чтобы письма реально отправлялись.
# Пока SMTP_HOST пустой — письма не уходят, а пишутся в лог сервера.
#
# Яндекс.Почта (нужен «пароль приложения», НЕ основной пароль ящика):
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Примеры значений для Яндекса:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_USER=priem@yandex.ru
#   SMTP_PASS=пароль_приложения
#   SMTP_FROM=Приём Солнечногорск <priem@yandex.ru>
#
# Для Mail.ru: SMTP_HOST=smtp.mail.ru (порт 465, secure true)
